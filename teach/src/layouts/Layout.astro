---
// The single page chrome: <head>, global styles, the one nav, the
// ask-teacher footer. Every page and lesson routes through here so the
// header can no longer drift between files.
import { getCollection } from 'astro:content';
import CourseNav from '../components/CourseNav.astro';
import Toc from '../islands/Toc.tsx';
import CourseRail from '../islands/CourseRail.tsx';
import { modules } from '../data/modules';
import '../styles/global.css';

interface Props {
  title: string;
  /** small uppercase kicker above the H1 */
  eyebrow?: string;
  /** current-location breadcrumb shown at the end of the nav */
  here?: string;
  /** the module this page belongs to — lights its dot in the left course rail */
  moduleNum?: number;
  /** the lesson id this page is — highlights its row in the rail flyout */
  lessonId?: string;
  /** hide the shared ask-teacher footer (e.g. the hub supplies its own) */
  footer?: boolean;
}
const { title, here, moduleNum, lessonId, footer = true } = Astro.props;

// The course spine for the left rail: each module plus its lessons (sorted),
// computed once here so the rail island gets a plain, serialisable tree and the
// lesson↔module mapping stays in the content collection, not duplicated.
const lessons = await getCollection('lessons');
const courseTree = modules.map((m) => ({
  num: m.num,
  title: m.title,
  href: m.href ?? null,
  checkId: m.checkId ?? null,
  unlockBy: m.unlockBy ?? null,
  lessons: lessons
    .filter((l) => l.data.module === m.num)
    .sort((a, b) => a.data.order - b.data.order)
    .map((l) => ({ id: l.id, order: l.data.order, title: l.data.title })),
}));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <CourseNav here={here} />
    <CourseRail tree={courseTree} currentModule={moduleNum} currentLesson={lessonId} client:idle />
    <main>
      <slot />
    </main>
    <Toc client:idle />
    {footer && (
      <div class="lesson-footer">
        <div class="ask-teacher">
          <strong>I'm your teacher.</strong> Ask anything that's unclear, or say
          <strong>"start Phase 1"</strong> when you're ready for the next module.
        </div>
      </div>
    )}
  </body>
</html>
