---
// Lesson 7 — Markup is a small SCENE GRAPH (ADR-0003). Three element kinds —
// Mark (decoration on words), Note (free text), Connector (arrow) — and a
// Connector endpoint or a Note pin binds to its target through a separate
// BINDING record, so ANY element can be a target. The inversion vs a whiteboard:
// no element stores absolute canvas x/y; every position resolves DOWN to a
// scripture Anchor (book·ch·verse·word-index), computed at render.
---
<svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" role="img"
     aria-label="A scene graph of Mark, Note and Connector whose endpoints and pins resolve, through Binding records, down to a scripture Anchor — never to canvas coordinates.">
  <defs>
    <marker id="sg-a" markerWidth="9" markerHeight="9" refX="7.5" refY="4.5" orient="auto">
      <path d="M0,0 L9,4.5 L0,9 z" fill="#9a7b27"/>
    </marker>
  </defs>

  <text class="ttl" x="40" y="32">A SCENE GRAPH — every element resolves to an Anchor, never to pixels</text>

  <!-- element nodes -->
  <g>
    <rect class="el" x="56" y="64" width="180" height="56" rx="7"/>
    <text class="eh" x="146" y="88" text-anchor="middle">Mark</text>
    <text class="ed" x="146" y="107" text-anchor="middle">underline · highlight · box</text>
  </g>
  <g>
    <rect class="el" x="290" y="64" width="180" height="56" rx="7"/>
    <text class="eh" x="380" y="88" text-anchor="middle">Note</text>
    <text class="ed" x="380" y="107" text-anchor="middle">free text · pinned + offset</text>
  </g>
  <g>
    <rect class="el" x="524" y="64" width="180" height="56" rx="7"/>
    <text class="eh" x="614" y="88" text-anchor="middle">Connector</text>
    <text class="ed" x="614" y="107" text-anchor="middle">arrow · joins two Endpoints</text>
  </g>

  <!-- a Connector can target another element (Note): the whiteboard back-ref we keep -->
  <path class="elink" d="M524,96 C500,96 470,96 470,96" marker-end="url(#sg-a)"/>
  <text class="elinkl" x="497" y="58" text-anchor="middle">endpoint → element</text>

  <!-- Binding layer -->
  <rect class="bind" x="56" y="168" width="648" height="46" rx="7"/>
  <text class="bh" x="72" y="190">BINDING</text>
  <text class="bd" x="150" y="190">a separate record per endpoint / pin — so any element can be a target</text>
  <text class="bd2" x="72" y="206">target = a scripture Anchor  ·OR·  another element’s id (mark | note)</text>

  <!-- arrows from elements down into Binding -->
  <path class="down" d="M146,120 L146,168" marker-end="url(#sg-a)"/>
  <path class="down" d="M380,120 L380,168" marker-end="url(#sg-a)"/>
  <path class="down" d="M614,120 L614,168" marker-end="url(#sg-a)"/>

  <!-- the Anchor row -->
  <rect class="anchor" x="180" y="266" width="400" height="58" rx="7"/>
  <text class="ah" x="380" y="290" text-anchor="middle">scripture ANCHOR</text>
  <text class="al" x="380" y="311" text-anchor="middle">book · chapter · verse · word-index   (+ offset for a free Note)</text>
  <path class="down" d="M380,214 L380,266" marker-end="url(#sg-a)"/>

  <!-- the inversion note -->
  <rect class="inv" x="56" y="266" width="108" height="58" rx="7"/>
  <text class="ix" x="110" y="290" text-anchor="middle">✗ no</text>
  <text class="ix" x="110" y="308" text-anchor="middle">canvas x/y</text>

  <text class="foot" x="596" y="299">unlike a whiteboard:</text>
  <text class="foot" x="596" y="315">the substrate moves,</text>
  <text class="foot" x="596" y="331">so coords would orphan</text>
</svg>

<style>
  .ttl   { font:700 12.5px Georgia, serif; fill:#1a1714; letter-spacing:.3px; }
  .el    { fill:#f4f0e4; stroke:#9a7b27; stroke-width:1.5; }
  .eh    { font:700 14px Georgia, serif; fill:#1a1714; }
  .ed    { font:italic 11px Georgia, serif; fill:#7a6a3a; }
  .elink { fill:none; stroke:#9a7b27; stroke-width:1.4; stroke-dasharray:4 3; }
  .elinkl{ font:italic 10px Georgia, serif; fill:#7a6a3a; }
  .bind  { fill:#f3ecdf; stroke:#d8cdb8; stroke-width:1.4; }
  .bh    { font:700 13px Georgia, serif; fill:#3a5a78; letter-spacing:.5px; }
  .bd    { font:13px Georgia, serif; fill:#1a1714; }
  .bd2   { font:italic 11.5px Georgia, serif; fill:#4a443d; }
  .down  { fill:none; stroke:#9a7b27; stroke-width:1.7; }
  .anchor{ fill:#fbf3dc; stroke:#9a7b27; stroke-width:1.8; }
  .ah    { font:700 14px Georgia, serif; fill:#1a1714; letter-spacing:.4px; }
  .al    { font:12px Georgia, serif; fill:#4a443d; }
  .inv   { fill:#fff; stroke:#9a3b2f; stroke-width:1.5; stroke-dasharray:5 4; }
  .ix    { font:700 12px Georgia, serif; fill:#9a3b2f; }
  .foot  { font:italic 11px Georgia, serif; fill:#7a6a3a; text-anchor:end; }
</style>
