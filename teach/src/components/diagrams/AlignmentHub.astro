---
// Lesson 9 — the fine, word-grain bridge (ADR-0007). A translation's TOKENS
// (corpus tier, white "spoke" boxes) align UP into the ORIGINAL WORD hub (gold
// "hub" boxes, echoing the Overview spokes/hubs visual) — but at word grain.
// Alignment is M:N: two English Tokens ("the beginning") converge on one Greek
// Original Word (ἀρχῇ). token.ow_id is the denormalized HEAD (one bold line per
// Token); interlinear_alignment is the full M:N set (every line). Hebrew strip
// at the bottom: one Written Word = several morpheme Original Words (segment_of).
---
<svg viewBox="0 0 760 430" xmlns="http://www.w3.org/2000/svg" role="img"
     aria-label="A translation's Tokens align up into the shared Original Word hub. Alignment is many-to-many: two English Tokens converge on one Greek word. token.ow_id is the head; the alignment table is the full set. Below, one Hebrew written word splits into several morpheme Original Words.">
  <defs>
    <marker id="al-a" markerWidth="9" markerHeight="9" refX="7.5" refY="4.5" orient="auto">
      <path d="M0,0 L9,4.5 L0,9 z" fill="#9a7b27"/>
    </marker>
  </defs>

  <text class="ttl" x="40" y="28">THE WORD-GRAIN BRIDGE — Tokens align up into the Original Word hub</text>

  <!-- corpus tier label -->
  <text class="tier" x="40" y="58">KJV TOKENS · corpus tier</text>

  <!-- translation tokens (white spoke boxes) -->
  <g>
    <rect class="tok" x="40"  y="66" width="104" height="40" rx="5"/><text class="tl" x="92"  y="91" text-anchor="middle">In</text>
    <rect class="tok" x="156" y="66" width="104" height="40" rx="5"/><text class="tl" x="208" y="91" text-anchor="middle">the</text>
    <rect class="tok" x="272" y="66" width="104" height="40" rx="5"/><text class="tl" x="324" y="91" text-anchor="middle">beginning</text>
    <rect class="tok" x="388" y="66" width="104" height="40" rx="5"/><text class="tl" x="440" y="91" text-anchor="middle">was</text>
    <rect class="tok" x="504" y="66" width="104" height="40" rx="5"/><text class="tl" x="556" y="91" text-anchor="middle">the</text>
    <rect class="tok" x="620" y="66" width="104" height="40" rx="5"/><text class="tl" x="672" y="91" text-anchor="middle">Word</text>
  </g>

  <!-- alignment lines (Token bottom y=106 → hub top y=176). The two converging on ἀρχῇ are the M:N case. -->
  <path class="al"   d="M92,106  C92,140 100,150 100,176"/>
  <path class="al"   d="M208,106 C208,150 240,150 240,176"/>
  <path class="head" d="M324,106 C324,150 240,150 240,176" marker-end="url(#al-a)"/>
  <path class="head" d="M440,106 C440,150 380,150 380,176" marker-end="url(#al-a)"/>
  <path class="al"   d="M556,106 C556,150 520,150 520,176"/>
  <path class="head" d="M672,106 C672,150 660,150 660,176" marker-end="url(#al-a)"/>

  <!-- hub tier label -->
  <text class="tier gold" x="40" y="170">ORIGINAL WORD hub · shared occurrences (Greek)</text>

  <!-- original words (gold hub boxes) -->
  <g>
    <rect class="hub" x="40"  y="176" width="104" height="48" rx="6"/><text class="gk" x="92"  y="200" text-anchor="middle">Ἐν</text><text class="gl" x="92"  y="216" text-anchor="middle">en</text>
    <rect class="hub" x="184" y="176" width="120" height="48" rx="6"/><text class="gk" x="244" y="200" text-anchor="middle">ἀρχῇ</text><text class="gl" x="244" y="216" text-anchor="middle">archē · beginning</text>
    <rect class="hub" x="324" y="176" width="104" height="48" rx="6"/><text class="gk" x="376" y="200" text-anchor="middle">ἦν</text><text class="gl" x="376" y="216" text-anchor="middle">ēn · was</text>
    <rect class="hub" x="468" y="176" width="104" height="48" rx="6"/><text class="gk" x="520" y="200" text-anchor="middle">ὁ</text><text class="gl" x="520" y="216" text-anchor="middle">ho · the</text>
    <rect class="hub" x="612" y="176" width="112" height="48" rx="6"/><text class="gk" x="668" y="200" text-anchor="middle">λόγος</text><text class="gl" x="668" y="216" text-anchor="middle">logos · word</text>
  </g>

  <!-- M:N callout -->
  <text class="note" x="244" y="246" text-anchor="middle">two Tokens → one Original Word</text>
  <text class="note2" x="244" y="260" text-anchor="middle">(alignment is many-to-many)</text>

  <!-- legend -->
  <line class="head" x1="470" y1="247" x2="500" y2="247" marker-end="url(#al-a)"/>
  <text class="lg" x="506" y="251">bold = the head (token.ow_id), one per Token</text>
  <line class="al" x1="470" y1="263" x2="500" y2="263"/>
  <text class="lg" x="506" y="267">thin = the full M:N set (interlinear_alignment)</text>

  <!-- divider -->
  <line class="div" x1="40" y1="288" x2="720" y2="288"/>

  <!-- Hebrew morpheme strip: one Written Word = several morpheme Original Words -->
  <text class="tier" x="40" y="312">HEBREW · one Written Word, several morpheme Original Words</text>

  <rect class="word" x="40" y="324" width="180" height="62" rx="6"/>
  <text class="gk" x="130" y="350" text-anchor="middle">bərēʾšîṯ</text>
  <text class="gl" x="130" y="368" text-anchor="middle">one written word</text>
  <text class="gl" x="130" y="381" text-anchor="middle">"in the beginning"</text>

  <path class="seg" d="M220,355 L300,355" marker-end="url(#al-a)"/>

  <rect class="hub sm" x="304" y="324" width="150" height="62" rx="6"/>
  <text class="gk" x="379" y="349" text-anchor="middle">bə-</text>
  <text class="gl" x="379" y="366" text-anchor="middle">morpheme · "in"</text>
  <text class="gl" x="379" y="379" text-anchor="middle">Original Word</text>

  <rect class="hub sm" x="470" y="324" width="170" height="62" rx="6"/>
  <text class="gk" x="555" y="349" text-anchor="middle">rēʾšîṯ</text>
  <text class="gl" x="555" y="366" text-anchor="middle">morpheme · "beginning"</text>
  <text class="gl" x="555" y="379" text-anchor="middle">Original Word</text>

  <path class="bracket" d="M308,394 L308,400 L636,400 L636,394"/>
  <text class="note2" x="472" y="416" text-anchor="middle">grouped back into the Written Word by segment_of + segment_index</text>
</svg>

<style>
  .ttl   { font:700 12.5px Georgia, serif; fill:#1a1714; letter-spacing:.3px; }
  .tier  { font:italic 11px Georgia, serif; fill:#7a6a3a; }
  .tier.gold { fill:#9a7b27; }
  .tok   { fill:#fff; stroke:#d8cdb8; stroke-width:1.5; }
  .tl    { font:600 13px Georgia, serif; fill:#1a1714; }
  .hub   { fill:#fbf3dc; stroke:#9a7b27; stroke-width:1.8; }
  .hub.sm{ fill:#f4f0e4; }
  .word  { fill:#fff; stroke:#9a7b27; stroke-width:1.6; }
  .gk    { font:600 17px "Cardo", serif; fill:#1a1714; }
  .gl    { font:italic 10.5px Georgia, serif; fill:#7a6a3a; }
  .al    { fill:none; stroke:#c9b27a; stroke-width:1.3; }
  .head  { fill:none; stroke:#9a7b27; stroke-width:2.4; }
  .seg   { fill:none; stroke:#9a7b27; stroke-width:1.7; }
  .bracket { fill:none; stroke:#9a7b27; stroke-width:1.3; }
  .note  { font:700 11.5px Georgia, serif; fill:#3a5a78; }
  .note2 { font:italic 11px Georgia, serif; fill:#4a443d; }
  .lg    { font:11px Georgia, serif; fill:#4a443d; }
  .div   { stroke:#d8cdb8; stroke-width:1; stroke-dasharray:4 4; }
</style>
