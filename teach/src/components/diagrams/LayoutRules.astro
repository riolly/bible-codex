---
// Lesson 5 — presentation is a small RULES layer bound to the corpus by stable
// semantic keys (genre, role, book.slug, canonical coordinate), never token.id
// and never pixels. The typography cascade resolves base < genre < role < book
// (most specific wins). The COMPUTED layout (line breaks, per-token rects) is an
// ephemeral, rebuildable, never-synced cache. (ADR-0004.)
const tiers = [
  { k: 'base preset', d: 'the global starting point', w: 150 },
  { k: '+ genre', d: 'poetry · prose · heading', w: 210 },
  { k: '+ role', d: 'psalm_title · section · margin', w: 270 },
  { k: '+ book', d: 'e.g. Psalms', w: 330 },
];
const y = (i: number) => 64 + i * 46;
---
<svg viewBox="0 0 760 360" xmlns="http://www.w3.org/2000/svg" role="img"
     aria-label="A typography cascade resolving base, genre, role and book overrides, bound by semantic keys, with computed layout as an ephemeral cache.">
  <defs>
    <marker id="lr-a" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
      <path d="M0,0 L9,4.5 L0,9 z" fill="#9a7b27"/>
    </marker>
  </defs>

  <text class="ttl" x="40" y="36">PRESENTATION = a tiny RULES layer (synced)</text>

  <!-- the cascade -->
  {tiers.map((t, i) => (
    <g>
      <rect class="tier" x="56" y={y(i)} width={t.w} height="34" rx="5"/>
      <text class="tk" x="70" y={y(i) + 22}>{t.k}</text>
      <text class="td" x={70 + t.w - 14} y={y(i) + 22} text-anchor="end">{t.d}</text>
    </g>
  ))}
  <path class="prec" d="M44,70 L44,238" marker-end="url(#lr-a)"/>
  <text class="precl" x="30" y="160" text-anchor="middle" transform="rotate(-90 30 160)">most specific wins</text>

  <!-- semantic-key note -->
  <rect class="note" x="430" y="64" width="290" height="160" rx="6"/>
  <text class="nh" x="448" y="88">Bound by semantic key</text>
  <text class="nl" x="448" y="112">genre · role · book.slug ·</text>
  <text class="nl" x="448" y="132">canonical coordinate</text>
  <text class="nbad" x="448" y="160">✗ never token.id · ✗ never pixels</text>
  <text class="nl2" x="448" y="186">so a rule survives corpus re-ingest,</text>
  <text class="nl2" x="448" y="204">font change, and translation switch</text>

  <!-- computed layout = ephemeral -->
  <rect class="eph" x="56" y="262" width="664" height="62" rx="6"/>
  <text class="eh" x="72" y="286">COMPUTED LAYOUT — line breaks · per-token rects</text>
  <text class="el" x="72" y="308">ephemeral local cache · re-typeset on open (~120fps) · never synced, never the source of truth</text>
</svg>

<style>
  .ttl  { font:700 12px Georgia, serif; fill:#1a1714; letter-spacing:.4px; }
  .tier { fill:#fbf3dc; stroke:#9a7b27; stroke-width:1.4; }
  .tk   { font:700 13px Georgia, serif; fill:#1a1714; }
  .td   { font:italic 11.5px Georgia, serif; fill:#7a6a3a; }
  .prec { fill:none; stroke:#9a7b27; stroke-width:1.8; }
  .precl{ font:700 10px Georgia, serif; fill:#9a7b27; letter-spacing:.5px; }
  .note { fill:#f3ecdf; stroke:#d8cdb8; stroke-width:1.3; }
  .nh   { font:700 12px Georgia, serif; fill:#3a5a78; }
  .nl   { font:13px Georgia, serif; fill:#1a1714; }
  .nl2  { font:italic 11.5px Georgia, serif; fill:#4a443d; }
  .nbad { font:12px Georgia, serif; fill:#9a3b2f; }
  .eph  { fill:#fff; stroke:#b9ad93; stroke-width:1.3; stroke-dasharray:5 4; }
  .eh   { font:700 12px Georgia, serif; fill:#4a443d; letter-spacing:.4px; }
  .el   { font:italic 12px Georgia, serif; fill:#4a443d; }
</style>
