---
// ONE course nav — the single source of truth that fixes the old hand-copied
// drift. Just the canonical links: Course home · Architecture map · Glossary.
// The current location is shown by each page's eyebrow (above its H1), not a
// breadcrumb here — that only duplicated the eyebrow and read like a 4th link.
const links = [
  { href: '/', label: 'Course home' },
  { href: '/reference/architecture-map', label: 'Architecture map' },
  { href: '/glossary', label: 'Glossary' },
];
---
<nav class="course-nav">
  {links.map((l, i) => (
    <>
      {i > 0 && <span class="sep">·</span>}
      <a href={l.href}>{l.label}</a>
    </>
  ))}
</nav>
